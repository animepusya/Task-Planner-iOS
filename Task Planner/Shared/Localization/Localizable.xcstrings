    "Your purchase is pending approval. We'll unlock Pro as soon as Apple confirms it.": {
      "comment": "Message in a MonetizationNotice when a purchase is pending approval.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre achat est en attente de validation. Pro sera activé dès qu’Apple le confirmera."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Покупка ожидает подтверждения. Мы откроем Pro, как только Apple её подтвердит."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Kauf wartet auf Bestätigung. Wir schalten Pro frei, sobald Apple ihn bestätigt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu compra está pendiente de aprobación. Activaremos Pro en cuanto Apple la confirme."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "購入は確認待ちです。Appleの確認後すぐにProが有効になります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구매가 승인 대기 중입니다. Apple에서 확인되는 즉시 Pro가 활성화됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sua compra está pendente de aprovação. Vamos liberar o Pro assim que a Apple confirmar."
          }
        }
      }
