          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "할 일 동기화와 Apple 캘린더 일정 표시에는 전체 캘린더 접근 권한이 필요해요. 설정에서 허용하세요."
          }
        },
        "pt-BR": {
          "stringUnit": {
